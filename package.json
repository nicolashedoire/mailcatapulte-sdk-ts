{
  "name": "mailops",
  "version": "0.1.0",
  "description": "Official TypeScript SDK for MailOps — the self-hosted transactional email platform",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mailops",
    "email",
    "transactional",
    "sdk",
    "typescript",
    "smtp",
    "newsletter",
    "api"
  ],
  "author": "Nicolas Hedoire",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nicolashedoire/mailops-sdk-typescript"
  },
  "homepage": "https://github.com/nicolashedoire/mailops-sdk-typescript#readme",
  "bugs": {
    "url": "https://github.com/nicolashedoire/mailops-sdk-typescript/issues"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false
}
